{
  "name": "@mixpeek/ui",
  "version": "0.1.0",
  "description": "Mixpeek component library — shadcn/ui primitives + API-bound components with autonomous feedback loops",
  "main": "dist/ui.cjs.js",
  "module": "dist/ui.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/ui.esm.js",
      "require": "./dist/ui.cjs.js",
      "types": "./dist/index.d.ts"
